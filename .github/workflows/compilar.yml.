name: Gerar ELF PS2
on: [push, workflow_dispatch]
jobs:
  build:
    runs-on: ubuntu-latest
    container: ps2dev/ps2dev:latest
    steps:
      - uses: actions/checkout@v3
      - name: Compilando
        run: |
          make clean
          make
      - name: Baixar ELF
        uses: actions/upload-artifact@v4
        with:
          name: Executavel-PS2
          path: "*.ELF"
